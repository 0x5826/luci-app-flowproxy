{
	"luci-app-flowproxy": {
		"description": "Grant access to flowproxy configuration",
		"read": {
			"uci": [ "flowproxy" ],
			"ubus": {
				"luci.flowproxy": [ "*" ],
				"network.interface": [ "dump" ]
			}
		},
		"write": {
			"uci": [ "flowproxy" ],
			"ubus": {
				"luci.flowproxy": [ "*" ]
			}
		}
	}
}
