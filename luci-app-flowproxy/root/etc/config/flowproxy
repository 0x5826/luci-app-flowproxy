config flowproxy 'global'
	option enabled '0'
	option proxy_ip ''
	option interface 'br-lan'
	option tproxy_mark '100'
	option log_level 'info'
	option log_size '1024'
	option log_count '3'

# TCP 规则模版（后台参考，不在界面显示）
config template 'tcp_template'
	option name 'TCP规则模版'
	option protocol 'tcp'
	option priority '100'
	option use_no_proxy_src_mac '1'
	option use_no_proxy_src_ip '1'
	option use_no_proxy_dst_ip '1'
	option use_private_dst_ip '1'
	option use_chnroute_dst_ip '1'
	option use_no_proxy_ports '1'

# UDP 规则模版（后台参考，不在界面显示）
config template 'udp_template'
	option name 'UDP规则模版'
	option protocol 'udp'
	option priority '100'
	option use_no_proxy_src_mac '1'
	option use_no_proxy_src_ip '1'
	option use_no_proxy_dst_ip '1'
	option use_private_dst_ip '1'
	option use_chnroute_dst_ip '1'
	option use_no_proxy_ports '1'

# 用户规则（可自由增删改）
config rule
	option name 'TCP规则'
	option protocol 'tcp'
	option enabled '1'
	option priority '100'
	option use_no_proxy_src_mac '1'
	option use_no_proxy_src_ip '1'
	option use_no_proxy_dst_ip '1'
	option use_private_dst_ip '1'
	option use_chnroute_dst_ip '1'
	option use_no_proxy_ports '1'

config rule
	option name 'UDP规则'
	option protocol 'udp'
	option enabled '1'
	option priority '100'
	option use_no_proxy_src_mac '1'
	option use_no_proxy_src_ip '1'
	option use_no_proxy_dst_ip '1'
	option use_private_dst_ip '1'
	option use_chnroute_dst_ip '1'
	option use_no_proxy_ports '1'

# nftables set 配置
config nftset 'no_proxy_src_mac'
	option name 'no_proxy_src_mac'
	option enabled '1'
	option type 'ether_addr'
	option comment '不走代理的源MAC地址'

config nftset 'no_proxy_src_ip_v4'
	option name 'no_proxy_src_ip_v4'
	option enabled '1'
	option type 'ipv4_addr'
	option comment '不走代理的源IPv4地址'

config nftset 'no_proxy_dst_ip_v4'
	option name 'no_proxy_dst_ip_v4'
	option enabled '1'
	option type 'ipv4_addr'
	option comment '不走代理的目标IPv4地址'

config nftset 'private_dst_ip_v4'
	option name 'private_dst_ip_v4'
	option enabled '1'
	option type 'ipv4_addr'
	option comment '私有地址段（自动生成）'
	option auto_generate '1'

config nftset 'chnroute_dst_ip_v4'
	option name 'chnroute_dst_ip_v4'
	option enabled '1'
	option type 'ipv4_addr'
	option comment '中国路由地址段'
	option file_path '/usr/share/flowproxy/chnroute.txt'

config nftset 'no_proxy_dst_tcp_ports'
	option name 'no_proxy_dst_tcp_ports'
	option enabled '1'
	option type 'inet_service'
	option comment '不走代理的TCP端口'

config nftset 'no_proxy_dst_udp_ports'
	option name 'no_proxy_dst_udp_ports'
	option enabled '1'
	option type 'inet_service'
	option comment '不走代理的UDP端口'