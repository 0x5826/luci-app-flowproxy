{
	"luci-app-flowproxy": {
		"description": "Grant UCI and UBUS access for luci-app-flowproxy",
		"read": {
			"uci": [ "flowproxy" ],
			"ubus": {
				"luci-app-flowproxy": [ "get_status", "get_nft_status", "get_logs", "get_interfaces", "generate_nft_config", "get_nftset_content" ]
			}
		},
		"write": {
			"uci": [ "flowproxy" ],
			"ubus": {
				"luci-app-flowproxy": [ "clear_logs", "start_service", "stop_service", "restart_service", "add_nftset_element", "delete_nftset_element" ]
			}
		}
	}
}