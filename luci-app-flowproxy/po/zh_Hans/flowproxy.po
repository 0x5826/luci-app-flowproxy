# Settings & Common
msgid "traffic diversion based on nftables rules. the service will automatically start/stop when you click \"save & apply\"."
msgstr "基于 nftables 规则的流量分流。点击“保存并应用”后，服务将自动启动/停止。"

msgid "service status"
msgstr "服务状态"

msgid "current status"
msgstr "当前状态"

msgid "dns redirection"
msgstr "DNS 转发"

msgid "running"
msgstr "运行中"

msgid "stopped"
msgstr "已停止"

msgid "disabled"
msgstr "已禁用"

msgid "checking..."
msgstr "检测中..."

msgid "active protocols"
msgstr "生效协议"

msgid "active proxy server ip address"
msgstr "活动代理服务器 IP 地址"

msgid "basic settings"
msgstr "基础设置"

msgid "enable flowproxy"
msgstr "启用代理分流"

msgid "to enable or disable TCP and UDP protocols, please go to the \"Rules\" page."
msgstr "TCP 和 UDP 协议的开启或关闭，请到“规则”页面进行设置。"

msgid "proxy server ip address"
msgstr "代理服务器 IP 地址"

msgid "network interface"
msgstr "网络接口"

msgid "tproxy mark"
msgstr "TPROXY 标记值"

msgid "force upstream dns to proxy server"
msgstr "强制上游 DNS 为代理服务器"

msgid "when enabled, dnsmasq will use the proxy server as the upstream dns server. \"dns redirect\" feature will be disabled.<br/>note: the \"enable flowproxy\" option must also be turned on for this to take effect."
msgstr "启用后，dnsmasq 将使用代理服务器作为上游 DNS 服务器。“DNS 重定向”功能将被禁用。<br/>注意：必须同时勾选“启用代理分流”才能生效。"

msgid "proxy server dns port"
msgstr "代理服务器 DNS 端口"

# Rules Page
msgid "flowproxy - rules"
msgstr "代理分流 - 规则管理"

msgid "Manage diversion rules, mainly used to define which traffic should bypass the proxy server."
msgstr "管理分流规则，主要用于定义哪些流量不需要被分流到代理服务器。"

msgid "quick templates"
msgstr "快捷模版"

msgid "Quick add:"
msgstr "快速插入预设："

msgid "matching rules"
msgstr "匹配规则列表"

msgid "TCP Matching Rules"
msgstr "TCP 匹配规则列表"

msgid "UDP Matching Rules"
msgstr "UDP 匹配规则列表"

msgid "enabled"
msgstr "已启用"

msgid "name"
msgstr "名称"

msgid "protocol"
msgstr "协议"

msgid "match type"
msgstr "匹配类型"

msgid "match value"
msgstr "匹配值"

msgid "counter"
msgstr "计数器"

msgid "action"
msgstr "动作"

msgid "TCP diversion master switch"
msgstr "TCP 分流总开关"

msgid "UDP diversion master switch"
msgstr "UDP 分流总开关"

msgid "enable protocol"
msgstr "启用协议"

msgid "Click to add to BOTH TCP and UDP lists"
msgstr "点击以同时添加到 TCP 和 UDP 规则列表"

msgid "Master switch updated. Click \"Save & Apply\" at the bottom to take effect."
msgstr "总开关状态已更新。点击底部的“保存并应用”以正式生效。"

msgid "Reset only %s rules"
msgstr "仅重置 %s 规则"

msgid "reset %s templates"
msgstr "重置 %s 模版"

msgid "this will delete ALL current %s rules and generate default templates. are you sure?"
msgstr "这将删除当前所有 %s 规则并加载推荐的默认模版。确定吗？"

msgid "really delete this rule?"
msgstr "确定要删除这条规则吗？"

# Lists Page
msgid "flowproxy - lists"
msgstr "代理分流 - 名单管理"

msgid "manage nftables set collections. use the global \"save & apply\" button at the bottom to take effect."
msgstr "管理 nftables set 集合。使用底部的全局“保存并应用”按钮以生效。"

msgid "manage nftables set collections. you can use predefined lists or add custom ones at the bottom."
msgstr "管理 nftables set 集合。您可以使用预设名单或在底部添加自定义名单。"

msgid "elements"
msgstr "元素列表"

msgid "custom nftables sets"
msgstr "自定义 nftables 集合"

msgid "element type"
msgstr "元素类型"

msgid "auto_generate"
msgstr "自动生成"

