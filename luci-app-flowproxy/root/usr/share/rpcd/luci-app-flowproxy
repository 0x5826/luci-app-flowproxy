#!/bin/sh

. /lib/functions.sh
. /usr/share/libubox/jshn.sh

UCI_CONFIG="flowproxy"
LOG_FILE="/var/log/flowproxy.log"
NFT_TABLE="flowproxy"

json_init

get_status() {
    local enabled running
    enabled=$(uci_get "$UCI_CONFIG" global enabled 0)

    # 通过检查 nftables 链判断运行状态
    nft list chain inet "$NFT_TABLE" LAN_MARKFLOW_TCP >/dev/null 2>&1 && running=1 || running=0

    json_add_object "status"
    json_add_int "enabled" "$enabled"
    json_add_int "running" "$running"
    json_add_string "proxy_ip" "$(uci_get "$UCI_CONFIG" global proxy_ip)"
    json_add_string "interface" "$(uci_get "$UCI_CONFIG" global interface 'br-lan')"
    json_add_string "tproxy_mark" "$(uci_get "$UCI_CONFIG" global tproxy_mark '100')"
    json_close_object
}

get_nft_status() {
    local tcp udp
    nft list chain inet "$NFT_TABLE" LAN_MARKFLOW_TCP >/dev/null 2>&1 && tcp=1 || tcp=0
    nft list chain inet "$NFT_TABLE" LAN_MARKFLOW_UDP >/dev/null 2>&1 && udp=1 || udp=0
    
    json_add_object "nftables"
    json_add_int "tcp_chain" "$tcp"
    json_add_int "udp_chain" "$udp"
    json_close_object
}

get_logs() {
    local lines="${1:-100}"
    json_add_array "logs"
    if [ -f "$LOG_FILE" ]; then
        local line
        while IFS= read -r line; do
            json_add_string "" "$line"
        done <<EOF
$(tail -n "$lines" "$LOG_FILE" 2>/dev/null)
EOF
    fi
    json_close_array
}

clear_logs() {
    > "$LOG_FILE" 2>/dev/null
    json_add_boolean "success" 1
}

get_interfaces() {
    json_add_array "interfaces"
    for iface in /sys/class/net/*; do
        [ -d "$iface" ] || continue
        json_add_object ""
        json_add_string "name" "$(basename "$iface")"
        json_add_string "mac" "$(cat "$iface/address" 2>/dev/null)"
        json_close_object
    done
    json_close_array
}

generate_nft_config() {
    local proxy_ip=$(uci_get "$UCI_CONFIG" global proxy_ip)
    local tproxy_mark=$(uci_get "$UCI_CONFIG" global tproxy_mark "100")
    
    local config="# FlowProxy nftables Configuration
# Generated: $(date)

table inet $NFT_TABLE {
    set no_proxy_src_mac { type ether_addr; }
    set no_proxy_src_ip_v4 { type ipv4_addr; }
    set no_proxy_dst_ip_v4 { type ipv4_addr; }
    set private_dst_ip_v4 { type ipv4_addr; }
    set chnroute_dst_ip_v4 { type ipv4_addr; }
    set no_proxy_dst_tcp_ports { type inet_service; }
    set no_proxy_dst_udp_ports { type inet_service; }
"
    
    config_load "$UCI_CONFIG"
    
    # TCP 链
    config="${config}

    chain LAN_MARKFLOW_TCP {
        type filter hook prerouting priority 100; policy accept;
        fib daddr type { unspec, local, anycast, multicast } counter return
"
    config_foreach _gen_rule rule tcp
    config="${config}    }"
    
    # UDP 链
    config="${config}

    chain LAN_MARKFLOW_UDP {
        type filter hook prerouting priority 100; policy accept;
        fib daddr type { unspec, local, anycast, multicast } counter return
"
    config_foreach _gen_rule rule udp
    config="${config}    }
}"
    
    json_add_string "config" "$config"
}

_gen_rule() {
    local section="$1"
    local proto="$2"
    local enabled protocol name
    
    config_get_bool enabled "$section" enabled 1
    [ "$enabled" -eq 0 ] && return
    
    config_get protocol "$section" protocol
    [ "$protocol" != "$proto" ] && return
    
    config_get name "$section" name
    
    local use_src_mac use_src_ip use_dst_ip use_private use_chnroute use_ports
    config_get_bool use_src_mac "$section" use_no_proxy_src_mac 1
    config_get_bool use_src_ip "$section" use_no_proxy_src_ip 1
    config_get_bool use_dst_ip "$section" use_no_proxy_dst_ip 1
    config_get_bool use_private "$section" use_private_dst_ip 1
    config_get_bool use_chnroute "$section" use_chnroute_dst_ip 1
    config_get_bool use_ports "$section" use_no_proxy_ports 1
    
    local proxy_ip=$(uci_get "$UCI_CONFIG" global proxy_ip)
    local tproxy_mark=$(uci_get "$UCI_CONFIG" global tproxy_mark "100")
    
    config="${config}
        # $name"
    
    [ "$use_src_mac" -eq 1 ] && config="${config}
        ether saddr @no_proxy_src_mac ip protocol $proto counter return"
    
    config="${config}
        ip saddr $proxy_ip ip protocol $proto counter return"
    
    [ "$use_src_ip" -eq 1 ] && config="${config}
        ip saddr @no_proxy_src_ip_v4 ip protocol $proto counter return"
    [ "$use_dst_ip" -eq 1 ] && config="${config}
        ip daddr @no_proxy_dst_ip_v4 ip protocol $proto counter return"
    [ "$use_private" -eq 1 ] && config="${config}
        ip daddr @private_dst_ip_v4 ip protocol $proto counter return"
    [ "$use_chnroute" -eq 1 ] && config="${config}
        ip daddr @chnroute_dst_ip_v4 ip protocol $proto counter return"
    
    if [ "$use_ports" -eq 1 ]; then
        if [ "$proto" = "tcp" ]; then
            config="${config}
        tcp dport @no_proxy_dst_tcp_ports counter return"
        else
            config="${config}
        udp dport @no_proxy_dst_udp_ports counter return"
        fi
    fi
    
    config="${config}
        ip protocol $proto counter meta mark set $tproxy_mark
"
}

start_service() { /etc/init.d/flowproxy start; json_add_boolean "success" $?; }
stop_service() { /etc/init.d/flowproxy stop; json_add_boolean "success" $?; }
restart_service() { /etc/init.d/flowproxy restart; json_add_boolean "success" $?; }

case "$1" in
    list)
        json_init
        json_add_object "get_status"; json_close_object
        json_add_object "get_nft_status"; json_close_object
        json_add_object "get_logs"
        json_add_string "lines" "integer"
        json_close_object
        json_add_object "clear_logs"; json_close_object
        json_add_object "get_interfaces"; json_close_object
        json_add_object "generate_nft_config"; json_close_object
        json_add_object "start_service"; json_close_object
        json_add_object "stop_service"; json_close_object
        json_add_object "restart_service"; json_close_object
        json_dump
        ;;
    call)
        json_init
        [ -n "$3" ] && json_load "$3"
        case "$2" in
            get_status) get_status ;;
            get_nft_status) get_nft_status ;;
            get_logs) json_get_var lines "lines"; get_logs "${lines:-100}" ;;
            clear_logs) clear_logs ;;
            get_interfaces) get_interfaces ;;
            generate_nft_config) config_load "$UCI_CONFIG"; generate_nft_config ;;
            start_service) start_service ;;
            stop_service) stop_service ;;
            restart_service) restart_service ;;
            *) json_add_string "error" "Unknown method" ;;
        esac
        json_dump
        ;;
    *)
        echo "Usage: $0 {list|call method [params]}"
        exit 1
        ;;
esac