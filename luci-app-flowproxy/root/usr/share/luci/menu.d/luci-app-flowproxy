#!/bin/sh

. /lib/functions.sh
. /usr/share/libubox/jshn.sh

case "$1" in
	list)
		json_init
		json_add_object "get_status"
		json_close_object
		json_add_object "get_nft_status"
		json_close_object
		json_add_object "get_logs"
		json_close_object
		json_add_object "get_interfaces"
		json_close_object
		json_add_object "generate_nft_config"
		json_close_object
		json_add_object "get_nftset_content"
			json_add_string "set_name" "name"
		json_close_object
		json_add_object "clear_logs"
		json_close_object
		json_add_object "start_service"
		json_close_object
		json_add_object "stop_service"
		json_close_object
		json_add_object "restart_service"
		json_close_object
		json_add_object "add_nftset_element"
			json_add_string "set_name" "name"
			json_add_string "element" "ip"
		json_close_object
		json_add_object "delete_nftset_element"
			json_add_string "set_name" "name"
			json_add_string "element" "ip"
		json_close_object
		json_dump
		exit 0
	;;
	call)
		case "$2" in
			get_status)
				json_init
				# 示例：检查进程是否存在，请根据实际情况修改匹配字符串
				if pgrep -f "flowproxy" >/dev/null; then
					json_add_boolean "running" 1
				else
					json_add_boolean "running" 0
				fi
				json_dump
			;;
			get_logs)
				json_init
				# 示例：读取日志
				[ -f "/var/log/flowproxy.log" ] && json_add_string "logs" "$(tail -n 50 /var/log/flowproxy.log)"
				json_dump
			;;
			*)
				# 其他方法需在此处实现，暂时返回空 JSON 防止报错
				json_init
				json_dump
			;;
		esac
	;;
esac